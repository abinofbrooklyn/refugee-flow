        <source
          src="https://player.vimeo.com/external/278983563.hd.mp4?s=df2675a8395d48ad7b455f155ae148361121b298&profile_id=175"
        />
      </video>
      <p
        className="sc-fHjqPg jBKPgv"
      >
        "At 
        <i>
          sea
        </i>
        , a frightening number of refugees and migrants are dying each year. On 
        <i>
          land
        </i>
        , people fleeing war are finding their way blocked by closed 
        <i>
          borders
        </i>
        . Closing borders does not solve the problem"
      </p>
    </section>
  </div>
  <a
    className="sc-eeDRCX fEAIQe"
    href="/conflict"
  >
    Launch Visualization
  </a>
