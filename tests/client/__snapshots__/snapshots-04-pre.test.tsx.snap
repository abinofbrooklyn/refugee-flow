exports[`Pre-conversion snapshots — landing DesktopLanding renders 1`] = `
<div
  className="sc-cPiKLY siJvM"
>
  <a
    href="/"
    onClick={[Function]}
  >
    Refugee Flow
  </a>
  <div
    className="sc-dLMFT fktvkU"
    onClick={[Function]}
