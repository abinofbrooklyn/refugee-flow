DATABASE_URL=postgresql://rfuser:rfpassword@localhost:5432/refugeeflow
PORT=2700
NODE_ENV=development

# Production database (Supabase)
# DATABASE_URL_PRODUCTION=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Data Ingestion API Keys (Phase 4)
ACLED_EMAIL=your_acled_account_email
ACLED_PASSWORD=your_acled_account_password

# Admin shared secret (any long random string)
ADMIN_SECRET=your_random_secret_here

# Email alerts for ingestion failures (Resend)
RESEND_API_KEY=your_resend_api_key_here

# AWS Deployment (Phase 14 — set in AWS Secrets Manager, not in .env)
# These are NOT used locally — listed here for documentation only
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/refugee-flow-github-actions
# S3_BUCKET=refugee-flow-frontend-ACCOUNT
# CF_DIST_ID=EXXXXXXXXXX
